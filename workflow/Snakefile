rule all:
    input:
        "results/mass4l_combine_userlvl3.pdf"

rule scram:
    input:
        config["data"],
        config["code"]
    output:
        touch("results/scram_done.txt")
    container:
        "docker://docker.io/cmsopendata/cmssw_5_3_32"
    shell:
        "source /opt/cms/cmsset_default.sh "
        "&& scramv1 project CMSSW CMSSW_5_3_32 "
        "&& cd CMSSW_5_3_32/src "
        "&& eval `scramv1 runtime -sh` "
        "&& cp -r ../../code/HiggsExample20112012 . "
        "&& cd HiggsExample20112012/HiggsDemoAnalyzer "
        "&& scram b "
        "&& cd ../Level3 "
        "&& mkdir -p ../../../../results "

rule scram_Node_A:
    input:
        config["data"],
        config["code"]
    output:
        touch("results/scram_data_done.txt")
    container:
        "docker://docker.io/cmsopendata/cmssw_5_3_32"
    resources:
        kubernetes_queue="eosc-node-a"
    shell:
        "source /opt/cms/cmsset_default.sh "
        "&& scramv1 project CMSSW CMSSW_5_3_32 "
        "&& cd CMSSW_5_3_32/src "
        "&& eval `scramv1 runtime -sh` "
        "&& cp -r ../../code/HiggsExample20112012 . "
