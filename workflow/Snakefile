rule analyse_data_Node_A:
    input:
        config["data"],
        config["code"],
        "results/scram_data_done.txt"
    output:
        "results/DoubleMuParked2012C_10000_Higgs.root"
    container:
        "docker://docker.io/cmsopendata/cmssw_5_3_32"
    resources:
        kubernetes_queue="eosc-node-a"
    shell:
        "source /opt/cms/cmsset_default.sh "
        "&& cd CMSSW_5_3_32/src "
        "&& eval `scramv1 runtime -sh` "
        "&& cd HiggsExample20112012/HiggsDemoAnalyzer "
        "&& cd ../Level3 "
        "&& cmsRun demoanalyzer_cfg_level3data.py"
        "&& mv ../../../../results/tmpDoubleMuParked2012C_10000_Higgs.root ../../../../results/DoubleMuParked2012C_10000_Higgs.root" 

